# ============================================================
# EasyFind Inventory Engine — Environment Variables
# ============================================================
# Copy this file to .env for local development.
# NEVER commit .env to GitHub.
# All production values must be set in Render dashboard.
# Reference: docs/contracts/05_api_integration_contract.md
# ============================================================

# ── Node.js ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Meta WhatsApp Cloud API ───────────────────────────────────
# Permanent access token from Meta Developer Console
WHATSAPP_ACCESS_TOKEN=

# Phone Number ID (not the phone number itself)
WHATSAPP_PHONE_NUMBER_ID=

# Verify token — any string you choose; must match Meta Console
WHATSAPP_VERIFY_TOKEN=

# App ID
WHATSAPP_APP_ID=

# ── Google Sheets ─────────────────────────────────────────────
# The spreadsheet ID from the URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
GOOGLE_SPREADSHEET_ID=

# Full JSON content of the service account key file (single line)
# Generate from: Google Cloud Console → IAM → Service Accounts → Keys
GOOGLE_SERVICE_ACCOUNT_JSON=

# Sheet tab name — must match the exact tab name in the spreadsheet
# Defaults to "Live Tracking" if not set
GOOGLE_SHEET_NAME=Live Tracking

# ── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OpenAI (Placeholder — NOT active at this phase) ──────────
# Do not enable until Phase 7
OPENAI_API_KEY=
